# Frontend (Vite) environment — copy to .env.local and fill in.
# Only VITE_-prefixed, NON-SECRET values may live here; they ship to the browser.

# URL of the deployed/served analyze Edge Function.
# Local Supabase dev default:
VITE_ANALYZE_FUNCTION_URL=http://localhost:54321/functions/v1/analyze
# Deployed example:
# VITE_ANALYZE_FUNCTION_URL=https://<project-ref>.functions.supabase.co/analyze

# Supabase anon (public) key — required only when the function verifies JWTs.
# This is NOT a secret in the dangerous sense (it is the public anon key), but
# leave it blank for local `--no-verify-jwt` development.
# VITE_SUPABASE_ANON_KEY=
